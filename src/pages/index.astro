---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import PublicationItem from '../components/PublicationItem.astro';
import publications from '../data/publications.json';
import news from '../data/news.json';

const featuredPublications = publications
  .filter((pub: any) => pub.featured)
  .sort((a: any, b: any) => b.year - a.year);
---

<Layout title="Sarim Hashmi">
  <Header />
  <main>
    <section class="about-section">
      <div class="about-content">
        <p>
          I am a Research Engineer at <a href="https://mbzuai.ac.ae" target="_blank" rel="noopener">MBZUAI</a>, working with <a href="https://nilslukas.github.io" target="_blank" rel="noopener">Dr. Nils Lukas</a> on <strong>secure</strong>, <strong>private</strong>, and <strong>strategic</strong> machine learning. <strong>I am currently looking for PhD positions in AI security</strong>, with a particular focus on language-model agents that rely on retrieval, memory, and tools—systems in which many critical failures arise from the surrounding pipeline rather than the base model itself.
        </p>
        <p>
          My work spans the development of <a href="https://www.etihad.com/en-in/" target="_blank" rel="noopener">Etihad Airways</a>' conversational agent, including retrieval, planning, structured response generation, real-time voice agent integration, and a <em>UserLM</em> for stress-testing. I also contribute to <em>AdvSim2Real</em>, which aims to strengthen agentic systems through adversarial simulation. In parallel, I have worked on <em>PERSUADE</em>, a framework for auditing persuasion in LLMs, as well as research on authentic multimedia detection and vision-language robustness. Although these areas differ on the surface, they are connected by the same central concern: understanding how AI systems behave under pressure.
        </p>
        <p>
          Previously, I completed an MSc by Research in Computer Vision at MBZUAI under the supervision of <a href="https://mbzuai.ac.ae/study/faculty/mohammad-yaqub/" target="_blank" rel="noopener">Dr. Mohammad Yaqub</a>. Before that, I earned a BTech in Mechanical Engineering from <a href="https://jmi.ac.in/" target="_blank" rel="noopener">Jamia Millia Islamia</a> and worked on autonomous-vehicle research at <a href="https://www.iiitd.ac.in/" target="_blank" rel="noopener">IIIT Delhi</a> under <a href="https://www.iiitd.ac.in/anands" target="_blank" rel="noopener">Dr. Saket Anand</a>.
        </p>
        <div class="about-links">
          <a href="mailto:sarim.hashmi@mbzuai.ac.ae" class="about-link">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
            Email
          </a>
<a href="https://github.com/Sarim-MBZUAI" class="about-link" target="_blank" rel="noopener">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path></svg>
            GitHub
          </a>
          <a href="https://scholar.google.com/citations?user=RMcwdxkAAAAJ&hl=en" class="about-link" target="_blank" rel="noopener">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path></svg>
            Scholar
          </a>
          <a href="https://www.linkedin.com/in/sarim-hashmi-b10b35136/" class="about-link" target="_blank" rel="noopener">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-4 0v7h-4v-7a6 6 0 0 1 6-6z"></path><rect x="2" y="9" width="4" height="12"></rect><circle cx="4" cy="4" r="2"></circle></svg>
            LinkedIn
          </a>
        </div>
      </div>
      <div class="about-image">
        <img src="/images/profile.jpg" alt="Sarim Hashmi" class="profile-image" />
      </div>
    </section>

    <section class="mt-4">
      <div class="section-header">
        <h2 class="section-title">News</h2>
      </div>
      <ul class="news-list">
        {news.map((item: any) => (
          <li class="news-item">
            <span class="news-date">{item.date}</span>
            <span class="news-text">
              {item.isNew && <span class="news-new"><span class="news-new-dot"></span>NEW</span>}
              <span set:html={item.text} />
            </span>
          </li>
        ))}
      </ul>
    </section>

    <section class="mt-4">
      <div class="section-header">
        <h2 class="section-title">Publications</h2>
        <a href="/publications" class="section-link">View all &rarr;</a>
      </div>
      {featuredPublications.length > 0 ? (
        <div class="publications-list">
          {featuredPublications.map((pub) => (
            <PublicationItem
              title={pub.title}
              authors={pub.authors}
              venue={pub.venue}
              year={pub.year}
              month={pub.month}
              thumbnail={pub.thumbnail}
              links={pub.links}
            />
          ))}
        </div>
      ) : (
        <p class="empty-state">No publications yet.</p>
      )}
    </section>
    <div class="footer-spacer"></div>
  </main>
</Layout>

<style>
  .news-list {
    list-style: none;
    padding: 0 0.75rem 0 0;
    margin: 0;
    max-height: 420px;
    overflow-y: auto;
    scrollbar-width: thin;
    scrollbar-color: var(--border) transparent;
  }
  .news-list::-webkit-scrollbar {
    width: 6px;
  }
  .news-list::-webkit-scrollbar-track {
    background: transparent;
  }
  .news-list::-webkit-scrollbar-thumb {
    background: var(--border);
    border-radius: 3px;
  }
  .news-list::-webkit-scrollbar-thumb:hover {
    background: var(--text-muted);
  }
  .news-item {
    display: grid;
    grid-template-columns: 110px 1fr;
    gap: 1.25rem;
    padding: 0.85rem 0;
    border-bottom: 1px dashed var(--border);
    font-family: var(--font-sans);
    font-size: 0.9375rem;
    line-height: 1.55;
  }
  .news-item:last-child {
    border-bottom: none;
  }
  .news-date {
    color: var(--accent);
    font-variant-numeric: tabular-nums;
    font-weight: 500;
    white-space: nowrap;
  }
  .news-text {
    color: var(--text-muted);
  }
  .news-text strong {
    color: var(--text);
    font-weight: 600;
  }
  .news-text em {
    font-style: italic;
    color: var(--text);
  }
  .news-new {
    display: inline-flex;
    align-items: center;
    gap: 0.3em;
    background: #fde8ee;
    color: #c11e4a;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    padding: 2px 8px 2px 7px;
    border-radius: 999px;
    margin-right: 0.5rem;
    vertical-align: 1px;
  }
  .news-new-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #e11d48;
    display: inline-block;
  }
  :global([data-theme="dark"]) .news-new {
    background: #3a1520;
    color: #ff8aa3;
  }
  :global([data-theme="dark"]) .news-new-dot {
    background: #ff6b8a;
  }
  @media (max-width: 600px) {
    .news-list {
      max-height: 360px;
    }
    .news-item {
      grid-template-columns: 1fr;
      gap: 0.15rem;
      padding: 0.75rem 0;
    }
    .news-date {
      font-size: 0.8125rem;
    }
  }
</style>
