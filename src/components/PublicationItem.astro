---
interface Props {
  title: string;
  authors: string[];
  venue: string;
  year: number;
  month?: string;
  thumbnail?: string;
  links?: {
    paper?: string;
    code?: string;
    blog?: string;
    website?: string;
  };
}

const { title, authors, venue, year, month, thumbnail, links } = Astro.props;

// Just use venue, no year
const venueStr = venue;

// Highlight "Sarim Hashmi" in authors
const highlightedAuthors = authors.map(author => {
  if (author.toLowerCase().includes('sarim') || author.toLowerCase().includes('hashmi')) {
    return `<span class="highlight">${author}</span>`;
  }
  return author;
}).join(', ');

// Link title to paper, or website if no paper
const titleLink = links?.paper || links?.website;

// Build array of link items for proper separator handling
const linkItems: { label: string; url: string }[] = [];
if (links?.paper) linkItems.push({ label: 'Paper', url: links.paper });
if (links?.code) linkItems.push({ label: 'Code', url: links.code });
if (links?.blog) linkItems.push({ label: 'Blog', url: links.blog });
if (links?.website) linkItems.push({ label: 'Website', url: links.website });
---

<article class:list={["publication-item", { "no-thumbnail": !thumbnail }]}>
  {thumbnail && (
    <img src={thumbnail} alt={`Thumbnail for ${title}`} class="publication-thumbnail" loading="lazy" />
  )}
  <div class="publication-content">
    <h3>
      {titleLink ? (
        <a href={titleLink} target="_blank" rel="noopener">{title}</a>
      ) : (
        title
      )}
    </h3>
    <p class="publication-authors" set:html={highlightedAuthors} />
    <div class="publication-meta">
      <span class="publication-venue">{venueStr}</span>
      {linkItems.length > 0 && (
        <>
          <span class="meta-separator">·</span>
          {linkItems.map((item, i) => (
            <>
              {i > 0 && <span class="meta-separator">·</span>}
              <a href={item.url} class="publication-link" target="_blank" rel="noopener">{item.label}</a>
            </>
          ))}
        </>
      )}
    </div>
  </div>
</article>
